{
  "name": "agent-harness",
  "private": true,
  "workspaces": [
    "agent-browser",
    "harness-core",
    "lib/*"
  ],
  "scripts": {
    "dev:agent-browser": "npm --workspace agent-browser run dev",
    "postinstall": "node scripts/run-package-bin.mjs patch-package",
    "check:generated-files": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-generated-files-clean.ps1",
    "verify:agent-browser": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-agent-browser.ps1",
    "test:agent-browser": "npm --workspace agent-browser run test",
    "test:coverage:agent-browser": "npm --workspace agent-browser run test:coverage",
    "visual:agent-browser": "npm --workspace agent-browser run visual:smoke"
  },
  "overrides": {
    "@anthropic-ai/sdk": "0.91.1",
    "@anthropic-ai/claude-agent-sdk": {
      "@anthropic-ai/sdk": "0.91.1"
    },
    "fast-xml-parser": "^5.7.0",
    "marked": "18.0.2",
    "protobufjs": "^7.5.5",
    "@tootallnate/once": "3.0.1",
    "sqlite3": "6.0.1",
    "tar": "7.5.13",
    "undici": "7.25.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.91.1",
    "patch-package": "^8.0.1"
  }
}
