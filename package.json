{
  "name": "agent-harness",
  "private": true,
  "workspaces": [
    "agent-browser",
    "ext/*/*",
    "harness-core",
    "lib/*",
    "lib/workers/*"
  ],
  "scripts": {
    "dev:agent-browser": "npm --workspace agent-browser run dev",
    "postinstall": "node scripts/apply-workspace-patches.mjs",
    "check:generated-files": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-generated-files-clean.ps1",
    "lint:extensions": "node scripts/run-extension-workspaces.mjs lint",
    "build:extensions": "node scripts/run-extension-workspaces.mjs build",
    "build:extension-downloads": "node scripts/package-extension-downloads.mjs",
    "test:extensions": "node scripts/run-extension-workspaces.mjs test",
    "test:coverage:extensions": "node scripts/run-extension-workspaces.mjs test:coverage",
    "test:canvas": "npm --workspace @agent-harness/ext-workflow-canvas-tests run test:unit",
    "visual:canvas": "npm --workspace @agent-harness/ext-workflow-canvas-tests run test:e2e",
    "verify:agent-browser": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/verify-agent-browser.ps1",
    "test:agent-browser": "npm --workspace agent-browser run test",
    "test:coverage:agent-browser": "npm --workspace agent-browser run test:coverage",
    "visual:agent-browser": "npm --workspace agent-browser run visual:smoke"
  },
  "overrides": {
    "@anthropic-ai/sdk": "0.95.0",
    "@anthropic-ai/claude-agent-sdk": "0.2.90",
    "@mongodb-js/zstd": "file:../../vendor/npm-stubs/mongodb-js-zstd",
    "fast-xml-parser": "5.7.3",
    "just-bash": "2.15.1-executor.0",
    "marked": "18.0.2",
    "protobufjs": "^7.5.5",
    "onnxruntime-node": "1.26.0",
    "@tootallnate/once": "3.0.1",
    "ip-address": "10.2.0",
    "sqlite3": "6.0.1",
    "tar": "7.5.13",
    "undici": "7.25.0",
    "express-rate-limit": {
      "ip-address": "10.2.0"
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.95.0",
    "patch-package": "^8.0.1"
  }
}
