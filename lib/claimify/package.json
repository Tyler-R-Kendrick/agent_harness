{
  "name": "@agent-harness/claimify",
  "version": "0.1.0",
  "description": "Browser-local Claimify-style factual claim extraction utilities",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "README.md",
    "src/**/*.ts",
    "!src/__tests__/**"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./worker-client": "./src/worker-client.ts",
    "./worker": "./src/worker.ts"
  },
  "scripts": {
    "test": "node ../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../scripts/run-package-bin.mjs vitest run --coverage"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^4.0.0"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
