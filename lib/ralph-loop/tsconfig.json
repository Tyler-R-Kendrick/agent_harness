{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "..",
    "paths": {
      "logact": ["../logact/src/index.ts"]
    },
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts", "../logact/src/**/*.ts"],
  "exclude": ["src/__tests__/**", "../logact/src/__tests__/**"]
}