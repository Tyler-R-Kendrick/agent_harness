{
  "name": "@agent-harness/harness-archive",
  "version": "0.1.0",
  "description": "Content-addressed harness-variant archive with parent lineage and eval scores, backed by harness-core ArtifactRegistry",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["README.md", "src/**/*.ts", "!src/**/*.test.ts", "!src/__tests__/**"],
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "test": "node ../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../scripts/run-package-bin.mjs vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5",
    "harness-core": "0.1.0"
  }
}
