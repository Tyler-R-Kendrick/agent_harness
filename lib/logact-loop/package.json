{
  "name": "@agent-harness/logact-loop",
  "version": "0.1.0",
  "description": "LogAct workflow extension for the generic harness-core agent event loop",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "README.md",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node ../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../scripts/run-package-bin.mjs vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "harness-core": "0.1.0",
    "logact": "0.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
