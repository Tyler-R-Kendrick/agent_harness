{
  "name": "inbrowser-use",
  "version": "0.1.0",
  "description": "Playwright-shaped in-app DOM control runtime running inside a website",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "README.md",
    "src/**/*.ts",
    "!src/__tests__/**"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node ../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../scripts/run-package-bin.mjs vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
