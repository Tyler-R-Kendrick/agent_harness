{
  "name": "@agent-harness/lean-browser",
  "version": "0.1.0",
  "description": "Browser-local Lean-backed agentic validation utilities",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "README.md",
    "public/lean/README.md",
    "src/**/*.ts",
    "!src/__tests__/**"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts"
  },
  "sideEffects": false,
  "scripts": {
    "test": "node ../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../scripts/run-package-bin.mjs vitest run --coverage",
    "typecheck": "node ../../scripts/run-package-bin.mjs typescript -p tsconfig.json --noEmit",
    "build": "node ../../scripts/run-package-bin.mjs typescript -p tsconfig.json"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
