{
  "name": "harness-core",
  "version": "0.1.0",
  "description": "Reusable agent loop core for agent_harness",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "README.md",
    "src/**/*.ts",
    "!src/__tests__/**"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node ../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../scripts/run-package-bin.mjs vitest run --coverage"
  },
  "dependencies": {
    "logact": "0.1.0",
    "xstate": "^5.31.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
