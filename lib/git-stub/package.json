{
  "name": "@agent-harness/git-stub",
  "version": "0.1.0",
  "description": "Git-style command shim for Agent Browser just-bash session filesystems",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tyler-R-Kendrick/agent_harness/tree/main/lib/git-stub"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "README.md",
    "src/**/*.ts",
    "!src/__tests__/**",
    "!src/**/*.test.ts"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node ../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../scripts/run-package-bin.mjs vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
