{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "inbrowser-use": ["../lib/inbrowser-use/src/index.ts"],
      "logact": ["../lib/logact/src/index.ts"],
      "harness-core/ext/agent-skills": ["../harness-core/src/ext/agent-skills.ts"],
      "harness-core/ext/agents-md": ["../harness-core/src/ext/agents-md.ts"],
      "harness-core": ["../harness-core/src/index.ts"],
      "ralph-loop": ["../lib/ralph-loop/src/index.ts"],
      "webmcp": ["../lib/webmcp/src/index.ts"],
      "@agent-harness/webmcp": ["../lib/webmcp/src/index.ts"],
      "agent-browser-mcp": ["../lib/agent-browser-mcp/src/index.ts"]
    }
  },
  "include": ["src"]
}
