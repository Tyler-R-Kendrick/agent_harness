{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@agent-harness/ext-agent-skills": ["../ext/agent-skills/src/index.ts"],
      "@agent-harness/ext-agents-md": ["../ext/agents-md/src/index.ts"],
      "@agent-harness/ext-artifacts": ["../ext/artifacts/src/index.ts"],
      "@agent-harness/ext-design-md": ["../ext/design-md/src/index.ts"],
      "@agent-harness/ext-symphony": ["../ext/symphony/src/index.ts"],
      "@agent-harness/ext-workflow-canvas": ["../ext/workflow-canvas/src/index.ts"],
      "@agent-harness/ext-local-model-connector": ["../ext/local-model-connector/src/index.ts"],
      "inbrowser-use": ["../lib/inbrowser-use/src/index.ts"],
      "logact": ["../lib/logact/src/index.ts"],
      "harness-core": ["../harness-core/src/index.ts"],
      "ralph-loop": ["../lib/ralph-loop/src/index.ts"],
      "webmcp": ["../lib/webmcp/src/index.ts"],
      "@agent-harness/webmcp": ["../lib/webmcp/src/index.ts"],
      "agent-browser-mcp": ["../lib/agent-browser-mcp/src/index.ts"]
    }
  },
  "include": ["src"]
}
