{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@agent-harness/ext-agent-skills": ["../ext/harness/agent-skills/src/index.ts"],
      "@agent-harness/ext-agents-md": ["../ext/harness/agents-md/src/index.ts"],
      "@agent-harness/ext-artifacts": ["../ext/ide/artifacts/src/index.ts"],
      "@agent-harness/ext-design-md": ["../ext/ide/design-md/src/index.ts"],
      "@agent-harness/ext-design-studio": ["../ext/ide/design-studio/src/index.ts"],
      "@agent-harness/workgraph": ["../lib/workgraph/src/index.ts"],
      "@agent-harness/ext-workflow-canvas": ["../ext/ide/workflow-canvas/src/index.ts"],
      "@agent-harness/ext-local-model-connector": ["../ext/provider/local-model-connector/src/index.ts"],
      "@agent-harness/agent-sandbox": ["../lib/agent-sandbox/src/index.ts"],
      "@agent-harness/git-stub": ["../lib/git-stub/src/index.ts"],
      "inbrowser-use": ["../lib/inbrowser-use/src/index.ts"],
      "logact": ["../lib/logact/src/index.ts"],
      "harness-core": ["../harness-core/src/index.ts"],
      "guidance-ts/src/gen": ["../harness-core/src/types/guidance-ts-gen.d.ts"],
      "ralph-loop": ["../lib/ralph-loop/src/index.ts"],
      "webmcp": ["../lib/webmcp/src/index.ts"],
      "@agent-harness/webmcp": ["../lib/webmcp/src/index.ts"],
      "agent-browser-mcp": ["../lib/agent-browser-mcp/src/index.ts"]
    }
  },
  "include": ["src"]
}
