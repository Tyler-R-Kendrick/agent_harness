{
  "name": "agent-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:cucumber": "npm run build && vite preview --host 127.0.0.1 --port 4173",
    "cucumber": "cucumber-js --config cucumber.mjs",
    "test:cucumber": "start-server-and-test \"npm run preview:cucumber\" http://127.0.0.1:4173 \"npm run cucumber\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "@copilotkit/react-core": "^1.54.1",
    "@huggingface/transformers": "^4.0.1",
    "@radix-ui/themes": "^3.3.0",
    "ai": "^6.0.153",
    "chat": "^4.24.0",
    "just-bash": "^2.14.1",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.5.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.1.0",
    "axe-core": "^4.9.0",
    "jsdom": "^24.0.0",
    "start-server-and-test": "^3.0.2",
    "typescript": "^5.4.0",
    "vite": "^6.4.2",
    "vitest": "^3.1.0"
  }
}
