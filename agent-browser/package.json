{
  "name": "agent-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "node ../scripts/run-package-bin.mjs typescript -b && node ../scripts/run-package-bin.mjs vite build",
    "cucumber": "node ../scripts/run-package-bin.mjs @cucumber/cucumber --config cucumber.mjs",
    "dev": "node ../scripts/run-package-bin.mjs vite --host 0.0.0.0 --port 5174 --strictPort",
    "dev:cucumber": "node ../scripts/run-package-bin.mjs vite --host 127.0.0.1 --port 4173 --strictPort",
    "eval:local-web-research": "node scripts/run-agentv-local-web-research-eval.mjs",
    "eval:composite-search": "node scripts/run-agentv-composite-search-eval.mjs",
    "eval:search": "node scripts/run-agentv-search-eval.mjs",
    "eval:search:live": "node scripts/run-agentv-search-eval.mjs --live",
    "eval:self-reflection": "node scripts/run-agentv-self-reflection-eval.mjs",
    "eval:tour-guide": "node scripts/run-agentv-tour-guide-eval.mjs",
    "lint": "node ../scripts/run-package-bin.mjs typescript -b --noEmit",
    "preview": "node ../scripts/run-package-bin.mjs vite preview",
    "preview:cucumber": "NODE_OPTIONS=--max-old-space-size=4096 npm run build && node ../scripts/run-package-bin.mjs vite preview --host 127.0.0.1 --port 4173",
    "proof:runtime-search": "node scripts/runtime-search-proof.mjs",
    "test": "node ../scripts/run-package-bin.mjs vitest run",
    "test:app": "node ../scripts/run-package-bin.mjs vitest run --config vitest.app.config.ts",
    "test:coverage": "node scripts/run-vitest-coverage.mjs",
    "test:cucumber": "node ../scripts/run-package-bin.mjs start-server-and-test \"npm run dev:cucumber\" http://127.0.0.1:4173 \"npm run cucumber\"",
    "test:eval-workflows": "node ../scripts/run-package-bin.mjs vitest run --config vitest.evals.config.ts",
    "test:evals": "node scripts/eval-manifest-validator.test.mjs",
    "test:scripts": "node scripts/run-script-tests.mjs",
    "test:watch": "node ../scripts/run-package-bin.mjs vitest",
    "validate:evals": "node scripts/eval-manifest-validator.mjs",
    "visual:smoke": "node scripts/visual-smoke.mjs"
  },
  "dependencies": {
    "@agent-harness/ext-agent-skills": "0.1.0",
    "@agent-harness/ext-agents-md": "0.1.0",
    "@agent-harness/ext-design-md": "0.1.0",
    "@agent-harness/ext-symphony": "0.1.0",
    "@ai-sdk/openai-compatible": "^1.0.15",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.23",
    "@cloudflare/codemode": "^0.3.4",
    "@cursor/sdk": "^1.0.12",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@github/copilot-sdk": "^0.2.2",
    "@huggingface/transformers": "4.0.1",
    "@perplexity-ai/perplexity_ai": "^0.27.0",
    "@radix-ui/themes": "^3.3.0",
    "@tavily/core": "^0.7.3",
    "@webcontainer/api": "^1.6.4",
    "ai": "^6.0.153",
    "chat": "^4.24.0",
    "dompurify": "^3.4.0",
    "driver.js": "^1.4.0",
    "fast-xml-parser": "^5.7.0",
    "harness-core": "0.1.0",
    "idb-keyval": "^6.2.2",
    "just-bash": "^2.14.1",
    "lucide-react": "^1.7.0",
    "marked": "18.0.2",
    "protobufjs": "^7.5.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.91.1",
    "@cucumber/cucumber": "^12.8.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "agentv": "^4.24.1",
    "axe-core": "^4.9.0",
    "jsdom": "^29.0.2",
    "start-server-and-test": "^3.0.2",
    "typescript": "^5.4.0",
    "vite": "^6.4.2",
    "vite-node": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-win32-arm64": "^1.2.4",
    "@img/sharp-libvips-win32-x64": "^1.2.4",
    "@img/sharp-win32-arm64": "^0.34.5",
    "@img/sharp-win32-x64": "^0.34.5"
  }
}
