      "categories": ["provider-extension", "model-provider", "chat-agent"],
      "metadata": {
        "marketplaceCategory": "provider",
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.cursor-model-provider.enabled"
      },
      "keywords": ["cursor", "models", "provider", "sdk"]
