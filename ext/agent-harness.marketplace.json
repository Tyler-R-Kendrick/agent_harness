{
  "schemaVersion": 1,
  "name": "Agent Harness default marketplace",
  "publisher": {
    "id": "agent-harness",
    "name": "Agent Harness"
  },
  "plugins": [
    {
      "id": "agent-harness.ext.agent-skills",
      "name": "Agent skills",
      "version": "0.1.0",
      "description": "Loads selected .agents/skills/*/SKILL.md files as optional tools and commands.",
      "manifest": "./harness/agent-skills/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./harness/agent-skills"
      },
      "categories": ["harness-extension", "workspace-context"],
      "metadata": {
        "marketplaceCategory": "harness",
        "installSurface": "virtual-fs"
      },
      "keywords": ["skills", "agent-skills"]
    },
    {
      "id": "agent-harness.ext.agents-md",
      "name": "AGENTS.md workspace instructions",
      "version": "0.1.0",
      "description": "Loads selected AGENTS.md files as optional prompt-context hooks.",
      "manifest": "./harness/agents-md/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./harness/agents-md"
      },
      "categories": ["harness-extension", "workspace-context"],
      "metadata": {
        "marketplaceCategory": "harness",
        "installSurface": "virtual-fs"
      },
      "keywords": ["agents-md", "instructions"]
    },
    {
      "id": "agent-harness.ext.design-md",
      "name": "DESIGN.md design tokens",
      "version": "0.1.0",
      "description": "Loads selected DESIGN.md files as optional design guidance and code-substitution assets.",
      "manifest": "./ide/design-md/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./ide/design-md"
      },
      "categories": ["ide-extension", "design", "workspace-context"],
      "metadata": {
        "marketplaceCategory": "ide",
        "activityIcon": "slidersHorizontal"
      },
      "keywords": ["design-md", "tokens", "css"]
    },
    {
      "id": "agent-harness.ext.symphony",
      "name": "Symphony workflow orchestration",
      "version": "0.1.0",
      "description": "Loads WORKFLOW.md assets and optional Symphony orchestration examples as a runtime extension.",
      "manifest": "./runtime/symphony/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./runtime/symphony"
      },
      "categories": ["runtime-extension", "workflow", "workspace-context"],
      "metadata": {
        "marketplaceCategory": "runtime",
        "runtimeEvents": ["llm", "agent", "tool"]
      },
      "keywords": ["symphony", "workflow-md", "orchestration"]
    },
    {
      "id": "agent-harness.ext.workflow-canvas",
      "name": "Workflow canvas orchestration",
      "version": "0.1.0",
      "description": "Creates CNCF Serverless Workflow-backed canvas artifacts for n8n-class automation and Higgsfield-style creative pipelines.",
      "manifest": "./ide/workflow-canvas/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./ide/workflow-canvas"
      },
      "categories": ["ide-extension", "workflow", "automation", "creative-canvas"],
      "metadata": {
        "marketplaceCategory": "ide",
        "activityIcon": "panes"
      },
      "keywords": ["cncf", "serverless-workflow", "n8n", "higgsfield", "canvas", "orchestration"]
    },
    {
      "id": "agent-harness.ext.artifacts",
      "name": "Artifacts",
      "version": "0.1.0",
      "description": "Adds Claude-style artifacts as standalone, versioned, downloadable context objects.",
      "manifest": "./ide/artifacts/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./ide/artifacts"
      },
      "categories": ["ide-extension", "workspace-context", "artifacts"],
      "metadata": {
        "marketplaceCategory": "ide",
        "activityIcon": "layers"
      },
      "keywords": ["artifacts", "claude-artifacts", "downloads"]
    },
    {
      "id": "agent-harness.ext.ghcp-model-provider",
      "name": "GitHub Copilot Models",
      "version": "0.1.0",
      "description": "Adds GitHub Copilot as an installable model-provider extension for GHCP chat agents.",
      "manifest": "./ghcp-model-provider/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./ghcp-model-provider"
      },
      "categories": ["model-provider", "chat-agent"],
      "keywords": ["ghcp", "github-copilot", "models", "provider"]
    },
    {
      "id": "agent-harness.ext.cursor-model-provider",
      "name": "Cursor Models",
      "version": "0.1.0",
      "description": "Adds Cursor SDK models as an installable model-provider extension.",
      "manifest": "./cursor-model-provider/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./cursor-model-provider"
      },
      "categories": ["model-provider", "chat-agent"],
      "keywords": ["cursor", "models", "provider", "sdk"]
    },
    {
      "id": "agent-harness.ext.codex-model-provider",
      "name": "Codex Models",
      "version": "0.1.0",
      "description": "Adds Codex CLI-backed models as an installable model-provider extension.",
      "manifest": "./codex-model-provider/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./codex-model-provider"
      },
      "categories": ["model-provider", "chat-agent"],
      "keywords": ["codex", "openai", "models", "provider"]
    },
    {
      "id": "agent-harness.ext.codi-browser-model-provider",
      "name": "Codi Browser Models",
      "version": "0.1.0",
      "description": "Adds browser-runnable Transformers.js and ONNX models as an installable local model-provider extension.",
      "manifest": "./codi-browser-model-provider/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./codi-browser-model-provider"
      },
      "categories": ["model-provider", "browser-local"],
      "keywords": ["codi", "hugging-face", "transformers-js", "onnx", "local-models"]
    },
    {
      "id": "agent-harness.ext.local-model-connector",
      "name": "Local Model Connector",
      "version": "0.1.0",
      "description": "Downloadable Chrome/Edge extension that brokers approved PWA requests to localhost OpenAI-compatible model endpoints.",
      "manifest": "./provider/local-model-connector/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./provider/local-model-connector/dist"
      },
      "categories": ["provider-extension", "model-provider", "browser-extension"],
      "metadata": {
        "marketplaceCategory": "provider",
        "accountConfig": "local-model-connector"
      },
      "keywords": ["local-models", "openai-compatible", "lm-studio", "ollama", "foundry-local", "chrome-extension"]
    },
    {
      "id": "agent-harness.ext.local-inference-daemon",
      "name": "Local Inference Daemon",
      "version": "0.1.0",
      "description": "Downloadable Deno background service for WebRTC or WebSocket access to loopback OpenAI-compatible local inference endpoints.",
      "manifest": "./daemon/local-inference-daemon/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./daemon/local-inference-daemon/dist"
      },
      "categories": ["daemon-extension", "model-provider", "daemon", "windows-service", "deno"],
      "metadata": {
        "marketplaceCategory": "daemon",
        "externalInstallDetection": "webrtc-peer"
      },
      "keywords": ["local-models", "openai-compatible", "webrtc", "websocket", "deno", "background-service"]
    }
  ]
}
