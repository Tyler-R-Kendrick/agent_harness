{
  "schemaVersion": 1,
  "name": "Agent Harness default marketplace",
  "publisher": {
    "id": "agent-harness",
    "name": "Agent Harness"
  },
  "plugins": [
    {
      "id": "agent-harness.ext.agent-skills",
      "name": "Agent skills",
      "version": "0.1.0",
      "description": "Loads selected .agents/skills/*/SKILL.md files as optional tools and commands.",
      "manifest": "./harness/agent-skills/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./harness/agent-skills"
      },
      "categories": ["harness-extension", "workspace-context"],
      "metadata": {
        "marketplaceCategory": "harness",
        "installSurface": "virtual-fs",
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.agent-skills.enabled"
      },
      "keywords": ["skills", "agent-skills"]
    },
    {
      "id": "agent-harness.ext.agents-md",
      "name": "AGENTS.md workspace instructions",
      "version": "0.1.0",
      "description": "Loads selected AGENTS.md files as optional prompt-context hooks.",
      "manifest": "./harness/agents-md/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./harness/agents-md"
      },
      "categories": ["harness-extension", "workspace-context"],
      "metadata": {
        "marketplaceCategory": "harness",
        "installSurface": "virtual-fs",
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.agents-md.enabled"
      },
      "keywords": ["agents-md", "instructions"]
    },
    {
      "id": "agent-harness.ext.design-md-context",
      "name": "DESIGN.md agent guidance",
      "version": "0.1.0",
      "description": "Loads selected DESIGN.md files into agent loops as design guidance, DTCG-aligned design tokens, and code-substitution context.",
      "manifest": "./harness/design-md/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./harness/design-md"
      },
      "categories": ["harness-extension", "workspace-context", "design-md", "design-tokens"],
      "metadata": {
        "marketplaceCategory": "harness",
        "installSurface": "prompt-context",
        "standardRefs": [
          "https://tr.designtokens.org/format/",
          "https://openfeature.dev/specification/"
        ],
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.design-md-context.enabled"
      },
      "keywords": ["design-md", "tokens", "css", "dtcg", "design-guidance"]
    },
    {
      "id": "agent-harness.ext.design-studio",
      "name": "Design Studio",
      "version": "0.1.0",
      "description": "Provides an IDE design-system surface for visually composing DESIGN.md systems as artifact-backed projects.",
      "manifest": "./ide/design-studio/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./ide/design-studio"
      },
      "categories": ["ide-extension", "design", "design-system", "design-md", "design-studio"],
      "metadata": {
        "marketplaceCategory": "ide",
        "activityIcon": "slidersHorizontal",
        "dependencies": [
          "agent-harness.ext.design-md-context",
          "agent-harness.ext.artifacts-context",
          "agent-harness.ext.artifacts-worktree"
        ],
        "standardRefs": [
          "https://tr.designtokens.org/format/"
        ],
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.design-studio.enabled"
      },
      "keywords": ["design-studio", "designstudio", "design-md", "design-system", "tokens"]
    },
    {
      "id": "agent-harness.ext.symphony",
      "name": "Symphony internal task orchestration",
      "version": "0.1.0",
      "description": "Exposes Symphony as an IDE extension backed by the internal durable task manager.",
      "manifest": "./runtime/symphony/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./runtime/symphony"
      },
      "categories": ["ide-extension", "runtime-extension", "workflow", "workspace-context"],
      "metadata": {
        "marketplaceCategory": "ide",
        "activityIcon": "puzzle",
        "runtimeEvents": ["llm", "agent", "tool"],
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.symphony.enabled"
      },
      "keywords": ["symphony", "workflow-md", "orchestration", "task-manager"]
    },
    {
      "id": "agent-harness.ext.workflow-canvas",
      "name": "Workflow canvas orchestration",
      "version": "0.1.0",
      "description": "Creates CNCF Serverless Workflow-backed canvas artifacts for n8n-class automation and Higgsfield-style creative pipelines.",
      "manifest": "./ide/workflow-canvas/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./ide/workflow-canvas"
      },
      "categories": ["ide-extension", "workflow", "automation", "creative-canvas"],
      "metadata": {
        "marketplaceCategory": "ide",
        "activityIcon": "panes",
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.workflow-canvas.enabled"
      },
      "keywords": ["cncf", "serverless-workflow", "n8n", "higgsfield", "canvas", "orchestration"]
    },
    {
      "id": "agent-harness.ext.artifacts-context",
      "name": "Artifact context",
      "version": "0.1.0",
      "description": "Lets agents use named artifacts in context through artifact tools and @artifact:name chat tokens.",
      "manifest": "./harness/artifacts/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./harness/artifacts"
      },
      "categories": ["harness-extension", "workspace-context", "artifacts", "chat-tokens"],
      "metadata": {
        "marketplaceCategory": "harness",
        "installSurface": "prompt-context",
        "chatTokenPrefix": "@artifact:",
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.artifacts-context.enabled"
      },
      "keywords": ["artifacts", "claude-artifacts", "downloads", "context", "autocomplete"]
    },
    {
      "id": "agent-harness.ext.artifacts-worktree",
      "name": "Artifact worktree explorer",
      "version": "0.1.0",
      "description": "Mounts artifacts as a worktree node so artifact bundles can be browsed alongside Browser, Files, and Sessions.",
      "manifest": "./ide/artifacts-worktree/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./ide/artifacts-worktree"
      },
      "categories": ["ide-extension", "workspace-tree", "artifacts"],
      "metadata": {
        "marketplaceCategory": "ide",
        "driveName": "//artifacts",
        "installSurface": "workspace-tree",
        "dependencies": ["agent-harness.ext.artifacts-context"],
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.artifacts-worktree.enabled"
      },
      "keywords": ["artifacts", "worktree", "explorer", "workspace-node"]
    },
    {
      "id": "agent-harness.ext.huggingface-model-provider",
      "name": "Hugging Face Browser Models",
      "version": "0.1.0",
      "description": "Adds Hugging Face Transformers.js and ONNX browser-runnable models as an installable local model-provider extension.",
      "manifest": "./codi-browser-model-provider/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./codi-browser-model-provider"
      },
      "categories": ["provider-extension", "model-provider", "browser-local"],
      "metadata": {
        "marketplaceCategory": "provider",
        "accountConfig": "huggingface-browser",
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.huggingface-model-provider.enabled"
      },
      "keywords": ["hugging-face", "transformers-js", "onnx", "local-models", "codi"]
    },
    {
      "id": "agent-harness.ext.ghcp-model-provider",
      "name": "GitHub Copilot Models",
      "version": "0.1.0",
      "description": "Adds GitHub Copilot as an installable model-provider extension for GHCP chat agents.",
      "manifest": "./ghcp-model-provider/agent-harness.plugin.json",
      "source": {
        "type": "local",
        "path": "./ghcp-model-provider"
      },
      "categories": ["provider-extension", "model-provider", "chat-agent"],
      "metadata": {
        "marketplaceCategory": "provider",
        "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.ghcp-model-provider.enabled"
      },
      "keywords": ["ghcp", "github-copilot", "models", "provider"]
    },
    {
      "id": "agent-harness.ext.cursor-model-provider",
      "name": "Cursor Models",
      "version": "0.1.0",
      "description": "Adds Cursor SDK models as an installable model-provider extension.",
      "manifest": "./cursor-model-provider/agent-harness.plugin.json",
      "source": {
        "type": "local",
