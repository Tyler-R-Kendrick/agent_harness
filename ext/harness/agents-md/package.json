{
  "name": "@agent-harness/ext-agents-md",
  "version": "0.1.0",
  "description": "Optional Agent Harness plugin for AGENTS.md workspace instruction assets.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "README.md",
    "agent-harness.plugin.json",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./agent-harness.plugin.json"
  },
  "scripts": {
    "lint": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "node ../../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../../scripts/run-package-bin.mjs vitest run --coverage"
  },
  "peerDependencies": {
    "harness-core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
