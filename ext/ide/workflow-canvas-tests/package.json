{
  "name": "@agent-harness/ext-workflow-canvas-tests",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "lint": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json --noEmit",
    "dev": "node ../../../scripts/run-package-bin.mjs vite",
    "test": "npm run test:unit",
    "test:unit": "node ../../../scripts/run-package-bin.mjs vitest run --config vitest.config.ts",
    "test:watch": "node ../../../scripts/run-package-bin.mjs vitest --config vitest.config.ts",
    "test:coverage": "node ../../../scripts/run-package-bin.mjs vitest run --coverage --config vitest.config.ts",
    "test:e2e": "node ../../../scripts/run-package-bin.mjs playwright test --config playwright.config.ts",
    "test:visual": "npm run test:e2e"
  },
  "dependencies": {
    "@agent-harness/ext-workflow-canvas": "0.1.0",
    "harness-core": "0.1.0",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^25.5.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
