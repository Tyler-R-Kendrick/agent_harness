{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "harness-core": ["../../harness-core-lint.d.ts"]
    },
    "types": ["vitest/globals", "node"]
  },
  "include": ["src/**/*.ts"]
}
