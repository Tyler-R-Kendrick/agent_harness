{
  "name": "@agent-harness/ext-symphony",
  "version": "0.1.0",
  "description": "Optional Agent Harness plugin for Symphony workflow orchestration.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "README.md",
    "agent-harness.plugin.json",
    "src/**/*.ts",
    "examples/**",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./board": "./src/board.ts",
    "./manifest": "./agent-harness.plugin.json"
  },
  "scripts": {
    "test": "node ../../scripts/run-package-bin.mjs vitest run",
    "test:watch": "node ../../scripts/run-package-bin.mjs vitest",
    "test:coverage": "node ../../scripts/run-package-bin.mjs vitest run --coverage"
  },
  "peerDependencies": {
    "harness-core": "0.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
