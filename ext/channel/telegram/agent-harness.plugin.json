{
  "schemaVersion": 1,
  "id": "agent-harness.ext.telegram-channel",
  "name": "Telegram Chat Channel",
  "version": "0.1.0",
  "description": "Adds Telegram as an installable chat delegation and continuation channel.",
  "entrypoint": {
    "module": "./src/index.ts",
    "export": "createTelegramChannelPlugin"
  },
  "contributes": {
    "channels": [
      {
        "id": "telegram",
        "label": "Telegram",
        "kind": "telegram",
        "capabilities": ["delegate", "continue", "notify", "handoff-link"],
        "description": "Delegate or continue an Agent Browser chat through a Telegram bot.",
        "configuration": {
          "type": "object",
          "properties": {
            "botUsername": { "type": "string" },
            "allowedChatIds": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    ]
  },
  "capabilities": [
    {
      "kind": "channel",
      "id": "telegram",
      "description": "Telegram chat session channel."
    }
  ],
  "permissions": [
    {
      "scope": "network",
      "access": "read-write",
      "reason": "The Telegram channel sends and receives chat handoff messages through configured Telegram Bot APIs."
    },
    {
      "scope": "secrets",
      "access": "read",
      "reason": "Provider tokens and signing secrets must stay in the configured secret store."
    }
  ],
  "compatibility": {
    "harnessCore": "^0.1.0",
    "agentBrowser": "^0.1.0"
  }
}
