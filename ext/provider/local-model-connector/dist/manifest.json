{
  "manifest_version": 3,
  "name": "Local Model Connector",
  "version": "0.1.0",
  "description": "Connects approved web apps to local OpenAI-compatible model endpoints.",
  "permissions": [
    "storage"
  ],
  "optional_host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "externally_connectable": {
    "matches": [
      "https://app.example.com/*",
      "https://app-dev.example.com/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "action": {
    "default_title": "Local Model Connector"
  }
}
