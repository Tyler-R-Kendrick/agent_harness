{
  "schemaVersion": 1,
  "id": "agent-harness.ext.xai-model-provider",
  "name": "xAI Models",
  "version": "0.1.0",
  "description": "Lists the xAI provider extension surface for future first-class account configuration.",
  "entrypoint": {
    "module": "./src/index.ts",
    "export": "createXaiModelProviderPlugin"
  },
  "metadata": {
    "availability": {
      "state": "unavailable",
      "reason": "Provider adapter is listed for marketplace planning but is not bundled in this runtime yet."
    },
    "openFeatureFlag": "agent-harness.extensions.agent-harness.ext.xai-model-provider.enabled"
  },
  "contributes": {
    "modelProviders": [
      {
        "id": "xai",
        "label": "xAI",
        "kind": "openai-compatible",
        "providerIds": ["xai"],
        "description": "Future xAI model-provider configuration."
      }
    ]
  },
  "capabilities": [
    {
      "kind": "model-provider",
      "id": "xai",
      "description": "xAI language models."
    }
  ],
  "compatibility": {
    "harnessCore": "^0.1.0",
    "agentBrowser": "^0.1.0"
  }
}
