{
	"image": "mcr.microsoft.com/devcontainers/universal:2",
	"hostRequirements": {
		"storage": "64gb"
	},
	"containerEnv": {
		"XDG_CACHE_HOME": "/tmp/devcontainer-cache/xdg",
		"NPM_CONFIG_CACHE": "/tmp/devcontainer-cache/npm",
		"UV_CACHE_DIR": "/tmp/devcontainer-cache/uv",
		"PLAYWRIGHT_BROWSERS_PATH": "/tmp/devcontainer-cache/ms-playwright"
	},
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"postStartCommand": "bash .devcontainer/post-start.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"GitHub.copilot-chat",
				"ms-vscode.js-debug-nightly",
				"ms-playwright.playwright",
				"vitest.explorer"
			]
		}
	},
	"features": {
		"ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1": {
			"shellautocompletion": true,
			"version": "latest"
		}
	}
}